OPENMEMORY_ENV=development
OPENMEMORY_HOST=127.0.0.1
OPENMEMORY_PORT=8765
OPENMEMORY_SQLITE_PATH=data/sqlite/openmemory.db
OPENMEMORY_CHROMA_PATH=data/chroma
OPENMEMORY_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5


# Intelligence layer: "none" (default) disables LLM features; engine stays heuristic
OPENMEMORY_LLM_PROVIDER=none
OPENMEMORY_OLLAMA_URL=http://127.0.0.1:11434
OPENMEMORY_OLLAMA_SUMMARIZER_MODEL=qwen2.5:3b
OPENMEMORY_OLLAMA_REASONER_MODEL=qwen3:8b

# Client security (M1): unset token = auth disabled; empty origins = CORS deny-all
OPENMEMORY_API_TOKEN=change-me
OPENMEMORY_CORS_ORIGINS=["chrome-extension://your-extension-id"]
